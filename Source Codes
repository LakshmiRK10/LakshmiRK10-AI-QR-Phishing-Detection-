"""
predict.py - Main Prediction Module
This module integrates all components:
- QR code decoding
- Feature extraction
- ML model prediction
- Result display
This is the main entry point for the application.
"""
import pickle
import os
import sys
# Import our custom modules
from qr_decoder import decode_qr_image, validate_url
from model import extract_features
def load_model(model_path):
    """
    Load the pre-trained ML model from file.
    
    Args:
        model_path (str): Path to the saved model file
        
    Returns:
        model: Loaded scikit-learn model, or None if loading fails
    """
    print(f"[*] Loading ML model from: {model_path}")
    
    try:
        with open(model_path, 'rb') as f:
            model = pickle.load(f)
        print("[+] Model loaded successfully!")
        return model
    except FileNotFoundError:
        print(f"[-] Error: Model file not found at {model_path}")
        print("[!] Please run model.py first to train the model")
        return None
    except Exception as e:
        print(f"[-] Error loading model: {e}")
        return None
def predict_url(model, url):
    """
    Predict whether a URL is safe or phishing.
    
    Args:
        model: Trained ML model
        url (str): URL to classify
        
    Returns:
        dict: Prediction result containing label, confidence, and features
    """
    # Extract features from the URL
    features = extract_features(url)
    
    # Make prediction
    prediction = model.predict([features])[0]
    
    # Get prediction probabilities (confidence scores)
    probabilities = model.predict_proba([features])[0]
    
    # Prepare result
    result = {
        'url': url,
        'prediction': 'PHISHING' if prediction == 1 else 'SAFE',
        'is_phishing': bool(prediction),
        'confidence': max(probabilities) * 100,
        'safe_probability': probabilities[0] * 100,
        'phishing_probability': probabilities[1] * 100,
        'features': features
    }
    
    return result
def display_result(result):
    """
    Display the prediction result in a formatted manner.
    
    Args:
        result (dict): Prediction result from predict_url()
    """
    print("\n" + "="*60)
    print("   PREDICTION RESULT")
    print("="*60)
    
    # Display URL (truncated if too long)
    url_display = result['url']
    if len(url_display) > 50:
        url_display = url_display[:50] + "..."
    print(f"\n  URL: {url_display}")
    
    # Display prediction with color coding (using ASCII)
    if result['is_phishing']:
        print(f"\n  ⚠️  STATUS: {result['prediction']} ⚠️")
        print("  " + "-"*40)
        print("  WARNING: This URL appears to be MALICIOUS!")
        print("  Do NOT click this link or enter any information.")
    else:
        print(f"\n  ✅ STATUS: {result['prediction']} ✅")
        print("  " + "-"*40)
        print("  This URL appears to be safe.")
    
    # Display confidence scores
    print(f"\n  Confidence Scores:")
    print(f"  • Safe probability:     {result['safe_probability']:.1f}%")
    print(f"  • Phishing probability: {result['phishing_probability']:.1f}%")
    
    # Display extracted features
    print(f"\n  Extracted Features:")
    feature_names = [
        'URL Length', 'Dots', 'Hyphens', 'Underscores', 'Slashes',
        'Digits', 'Special Chars', 'HTTPS', 'Has IP', 'Subdomains',
        'Path Length', 'Suspicious Words'
    ]
    
    for name, value in zip(feature_names, result['features']):
        print(f"  • {name}: {value}")
    
    print("\n" + "="*60)
def analyze_qr_code(image_path, model):
    """
    Complete pipeline: Decode QR code and analyze the URL.
    
    Args:
        image_path (str): Path to QR code image
        model: Trained ML model
        
    Returns:
        dict: Complete analysis result
    """
    print("\n" + "="*60)
    print("   AI-Based QR Code Phishing Detection System")
    print("="*60)
    
    # Step 1: Decode QR code
    print("\n[STEP 1] Decoding QR Code...")
    url = decode_qr_image(image_path)
    
    if not url:
        return {
            'success': False,
            'error': 'Failed to decode QR code'
        }
    
    print(f"[+] Decoded URL: {url}")
    
    # Step 2: Validate URL
    print("\n[STEP 2] Validating URL...")
    if not validate_url(url):
        print("[!] Warning: Decoded data may not be a valid URL")
        print("[!] Proceeding with analysis anyway...")
    else:
        print("[+] Valid URL format detected")
    
    # Step 3: Analyze URL
    print("\n[STEP 3] Analyzing URL with ML Model...")
    result = predict_url(model, url)
    
    # Step 4: Display result
    print("\n[STEP 4] Generating Report...")
    display_result(result)
    
    result['success'] = True
    return result
def main():
    """
    Main entry point for the prediction system.
    """
    print("\n" + "="*60)
    print("   AI-Based QR Code Phishing (Quishing) Detection")
    print("   Developed for BTech Cybersecurity Mini-Project")
    print("="*60)
    
    # Define model path
    model_path = os.path.join(os.path.dirname(__file__), '..', 'models', 'phishing_model.pkl')
    
    # Load the trained model
    model = load_model(model_path)
    
    if model is None:
        print("\n[!] Cannot proceed without trained model.")
        print("[!] Run 'python model.py' first to train the model.")
        sys.exit(1)
    
    # Get input from user
    print("\n" + "-"*60)
    print("Choose input method:")
    print("1. Analyze QR code image")
    print("2. Analyze URL directly")
    print("3. Run demo with sample URLs")
    print("-"*60)
    
    choice = input("\nEnter choice (1/2/3): ").strip()
    
    if choice == '1':
        # QR code analysis
        image_path = input("\nEnter path to QR code image: ").strip()
        
        if not image_path:
            print("[-] No image path provided")
            return
        
        analyze_qr_code(image_path, model)
        
    elif choice == '2':
        # Direct URL analysis
        url = input("\nEnter URL to analyze: ").strip()
        
        if not url:
            print("[-] No URL provided")
            return
        
        print("\n[*] Analyzing URL...")
        result = predict_url(model, url)
        display_result(result)
        
    elif choice == '3':
        # Demo mode with sample URLs
        print("\n[*] Running demo with sample URLs...\n")
        
        demo_urls = [
            "[google.com](https://www.google.com)",
            "[amazon.com](https://www.amazon.com/products)",
            "[192.168.1.1](http://192.168.1.1/login/secure/verify)",
            "[login-secure-bank-update.suspicious.com](http://login-secure-bank-update.suspicious.com/account)",
            "[github.com](https://github.com/user/repository)",
            "[free-prize-winner.com](http://free-prize-winner.com/claim-now)",
        ]
        
        for url in demo_urls:
            print("-"*60)
            result = predict_url(model, url)
            
            status = "⚠️  PHISHING" if result['is_phishing'] else "✅ SAFE"
            confidence = result['confidence']
            
            # Truncate long URLs
            url_display = url if len(url) <= 45 else url[:45] + "..."
            
            print(f"URL: {url_display}")
            print(f"Result: {status} (Confidence: {confidence:.1f}%)")
            print()
        
        print("-"*60)
        print("[+] Demo completed!")
        
    else:
        print("[-] Invalid choice")
        return
# Run main function when script is executed
if __name__ == "__main__":
    main()
