"""
qr_decoder.py - QR Code Decoding Module
This module handles:
- Reading QR code images from files
- Decoding QR codes to extract embedded URLs
- Validating decoded content
"""
import cv2
from pyzbar.pyzbar import decode
from PIL import Image
import os
def decode_qr_image(image_path):
    """
    Decode a QR code image and extract the embedded URL/data.
    
    This function uses two methods for decoding:
    1. OpenCV with pyzbar (primary method)
    2. PIL with pyzbar (fallback method)
    
    Args:
        image_path (str): Path to the QR code image file
        
    Returns:
        str: Decoded URL/data from the QR code, or None if decoding fails
    """
    print(f"\n[*] Attempting to decode QR code from: {image_path}")
    
    # Check if file exists
    if not os.path.exists(image_path):
        print(f"[-] Error: Image file not found at {image_path}")
        return None
    
    # Method 1: Try decoding with OpenCV
    try:
        print("[*] Trying OpenCV method...")
        
        # Read the image using OpenCV
        image = cv2.imread(image_path)
        
        if image is None:
            print("[-] OpenCV could not read the image")
        else:
            # Decode QR codes from the image
            decoded_objects = decode(image)
            
            if decoded_objects:
                # Extract data from the first QR code found
                qr_data = decoded_objects[0].data.decode('utf-8')
                print(f"[+] Successfully decoded using OpenCV!")
                return qr_data
            else:
                print("[-] No QR code found using OpenCV method")
                
    except Exception as e:
        print(f"[-] OpenCV method failed: {e}")
    
    # Method 2: Try decoding with PIL (fallback)
    try:
        print("[*] Trying PIL method (fallback)...")
        
        # Open image using PIL
        pil_image = Image.open(image_path)
        
        # Decode QR codes from the PIL image
        decoded_objects = decode(pil_image)
        
        if decoded_objects:
            # Extract data from the first QR code found
            qr_data = decoded_objects[0].data.decode('utf-8')
            print(f"[+] Successfully decoded using PIL!")
            return qr_data
        else:
            print("[-] No QR code found using PIL method")
            
    except Exception as e:
        print(f"[-] PIL method failed: {e}")
    
    # Both methods failed
    print("[-] Failed to decode QR code from image")
    return None
def validate_url(data):
    """
    Validate if the decoded data is a valid URL.
    
    Args:
        data (str): Decoded data from QR code
        
    Returns:
        bool: True if data appears to be a URL, False otherwise
    """
    if not data:
        return False
    
    # Check for common URL patterns
    url_indicators = ['http://', 'https://', 'www.', '.com', '.org', '.net', '.io']
    
    data_lower = data.lower()
    
    for indicator in url_indicators:
        if indicator in data_lower:
            return True
    
    return False
def get_qr_info(image_path):
    """
    Get detailed information about a QR code.
    
    Args:
        image_path (str): Path to the QR code image
        
    Returns:
        dict: Dictionary containing QR code information
    """
    info = {
        'success': False,
        'data': None,
        'is_url': False,
        'qr_type': None,
        'error': None
    }
    
    try:
        # Read the image
        image = cv2.imread(image_path)
        if image is None:
            image = Image.open(image_path)
        
        # Decode QR codes
        decoded_objects = decode(image)
        
        if decoded_objects:
            qr_object = decoded_objects[0]
            info['success'] = True
            info['data'] = qr_object.data.decode('utf-8')
            info['qr_type'] = qr_object.type
            info['is_url'] = validate_url(info['data'])
        else:
            info['error'] = "No QR code found in image"
            
    except Exception as e:
        info['error'] = str(e)
    
    return info
def main():
    """
    Test function for the QR decoder module.
    """
    print("="*60)
    print("   QR Code Decoder - Test Mode")
    print("="*60)
    
    # Test with a sample image (you can change this path)
    test_image = input("\nEnter path to QR code image: ").strip()
    
    if not test_image:
        print("[-] No image path provided")
        return
    
    # Decode the QR code
    result = decode_qr_image(test_image)
    
    if result:
        print(f"\n{'='*50}")
        print(f"DECODED CONTENT")
        print(f"{'='*50}")
        print(f"Data: {result}")
        print(f"Is URL: {validate_url(result)}")
        print(f"{'='*50}")
    else:
        print("\n[-] Could not decode the QR code")
# Run test when script is executed directly
if __name__ == "__main__":
    main()
